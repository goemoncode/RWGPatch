<patch>
  <append xpath="//world/property[contains(@class, 'wilderness')]">
    <property name="occupancy" value=".25,.5,.75"/>
  </append>
  <prepend xpath="/rwgmixer">
    <world name="default">
      <property name="world_size" value="0,99000"/>
      <property class="wilderness">
        <property name="occupancy" value=".25,.5,.75"/>
      </property>
      <property class="hills">
        <property name="occupancy" value=".2,.4,.6"/>
      </property>
      <property class="mountains">
        <property name="occupancy" value=".1,.2,.4"/>
      </property>
    </world>
  </prepend>

  <removeattribute xpath="//prefab_spawn_adjust[starts-with(@partial_name, 'trader_')]/@biomeTags" />
  <setattribute xpath="//prefab_spawn_adjust[starts-with(@partial_name, 'trader_')]" name="min_count">1</setattribute>
  <append xpath="/rwgmixer">
    <player_spawn min_count="5" max_count="30" range="600,900,1200" />
  </append>
</patch>